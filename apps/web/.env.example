# Copy to .env.local and fill in. Never commit real secrets (.env* is gitignored;
# only this .env.example template is committed).

# --- Database (Neon) ---
# Neon pooled connection string, e.g.
# postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/DB?sslmode=require
DATABASE_URL=

# --- Better Auth ---
# Generate a strong secret, e.g. `openssl rand -base64 32`
BETTER_AUTH_SECRET=
# Base URL of the app (no trailing slash). MUST be the exact origin the app is
# served from, since OAuth redirect URIs are derived from it.
#   local:      http://localhost:3000
#   production: https://app.topresume.me   (the subdomain the app runs on)
BETTER_AUTH_URL=http://localhost:3000
# Extra origins allowed to call the auth API (comma-separated, no trailing
# slash). The baseURL above is always trusted; list additional origins here,
# e.g. the marketing apex if sign-in is initiated from it. A mismatch causes a
# 403 from Better Auth's origin check.
#   production example: https://topresume.me
BETTER_AUTH_TRUSTED_ORIGINS=

# --- Google OAuth ---
# Google Cloud Console > Credentials > OAuth client (Web application)
# Authorized redirect URI: {BETTER_AUTH_URL}/api/auth/callback/google
#   local:      http://localhost:3000/api/auth/callback/google
#   production: https://app.topresume.me/api/auth/callback/google
# Authorized JavaScript origins: {BETTER_AUTH_URL} (e.g. https://app.topresume.me)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Apple Sign In ---
# APPLE_CLIENT_ID is your Services ID (e.g. com.yourapp.web).
# Redirect URI: {BETTER_AUTH_URL}/api/auth/callback/apple
APPLE_CLIENT_ID=
# Better Auth consumes a generated *client secret* (a JWT signed with your .p8
# key, valid <= 6 months). Generate it from the Team ID / Key ID / .p8 values
# below and paste the resulting JWT here (regenerate before it expires).
APPLE_CLIENT_SECRET=
# Optional: only needed if you also sign in from a native iOS app.
APPLE_APP_BUNDLE_IDENTIFIER=
# Inputs used to generate APPLE_CLIENT_SECRET (not read by the app directly):
APPLE_TEAM_ID=
APPLE_KEY_ID=
# The .p8 private key contents (keep the BEGIN/END lines; use \n for newlines)
APPLE_PRIVATE_KEY=

# --- Vercel Blob (photo storage) ---
BLOB_READ_WRITE_TOKEN=
